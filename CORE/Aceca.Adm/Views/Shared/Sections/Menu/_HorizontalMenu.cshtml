@{
    TempData.Keep();

    string? currentPage = ViewContext.HttpContext.Request.Path;

    ViewData["containerNav"] ??= "container-fluid";
}

<!-- Menu -->
<aside id="layout-menu" class="layout-menu-horizontal menu-horizontal  menu bg-menu-theme flex-grow-0">
    
    <div class='@ViewData["containerNav"] d-flex h-100'>
        @* ! Full version menu-items *@
        <ul class="menu-inner">

            <!-- Agenda -->
            <li class='menu-item@(currentPage.StartsWith("/Agenda") ? " active" : "")'>
                <a href="javascript:void(0)" class="menu-link menu-toggle">
                    <i class='menu-icon tf-icons ri-calendar-line'></i>
                    <div data-i18n="Agenda">Agenda</div>
                </a>

                <ul class="menu-sub">

                    <li class='menu-item@(currentPage == "/Agenda/Agenda" ? " active" : "")'>
                        <a asp-controller="Agenda" asp-action="Index" class="menu-link">
                            <i class='menu-icon tf-icons ri-article-line'></i>
                            <div data-i18n="Agenda">Agenda</div>
                        </a>
                    </li>

                    <li class='menu-item@(currentPage == "/Agenda/Imagem" ? " active" : "")'>
                        <a asp-controller="AgendaImagem" asp-action="Index" class="menu-link">
                            <i class="menu-icon tf-icons ri-computer-line"></i>
                            <div data-i18n="Imagem">Imagem</div>
                        </a>
                    </li>
                </ul>
