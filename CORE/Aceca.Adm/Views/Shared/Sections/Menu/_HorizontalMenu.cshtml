                            <i class="menu-icon tf-icons ri-archive-line"></i>
                            <div data-i18n="F&aacute;brica">F&aacute;brica</div>
                        </a>
                    </li>

                    <li class='menu-item@(currentPage == "/Fabrica/Fase" ? " active" : "")'>
