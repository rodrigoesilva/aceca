@{
    Layout = "_BlankLayout";
    ViewData["Title"] = "Login Basic - Pages";
}

@section VendorStyles {
    <link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
    <link rel="stylesheet" href="~/vendor/libs/typeahead-js/typeahead.css" />
    <link rel="stylesheet" href="~/vendor/libs/tagify/tagify.css" />
    <link rel="stylesheet" href="~/vendor/libs/&#64;form-validation/form-validation.css" />
}

@section VendorScripts {
    <script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
    <script src="~/vendor/libs/typeahead-js/typeahead.js"></script>
    <script src="~/vendor/libs/tagify/tagify.js"></script>
    <script src="~/vendor/libs/&#64;form-validation/popular.js"></script>
    <script src="~/vendor/libs/&#64;form-validation/bootstrap5.js"></script>
    <script src="~/vendor/libs/&#64;form-validation/auto-focus.js"></script>
}

@section PageStyles {
    <link rel="stylesheet" href="~/vendor/css/pages/page-auth.css">
        <link rel="stylesheet" href="~/css/style.css">
        }

        @section PageScripts {
    
            @* <script src="~/js/auth/pages-login.js"></script> *@
            <script src="~/js/auth/pages-auth.js"></script>
        }
        @* ************** Content ************** *@

        <div class="position-relative">
            <div class="authentication-wrapper authentication-basic container-p-y">
                <div class="authentication-inner py-6 mx-4">
                    <div class="pg-login">
                        <div class="login-bg">
                    
                            <img src="data:image/jpeg;base64,"
                                 alt="ACECA"
                                 class="login-bg-img">
                            <!--
                   
                    <img src="data:image/jpeg;base64,"
                        alt="ACECA"
                        class="login-bg-img">
                            
                    <div class="login-bg-overlay"></div>
                    -->

                            <div class="" style="position: absolute;inset: 0;"></div>
                        </div>
                
                        <div class="login-wrap">
                            <div class="login-card">
                                <div class="lc-logo">
                                    <div class="lc-circle">
                                        <img src="data:image/png;base64," alt="ACECA">
                                    </div>
                                    <div>
                                        <span class="lc-aceca">ACECA</span>
                                        <span class="lc-area">&Aacute;rea do S&oacute;cio</span>
                                    </div>
                                </div>
                                <h2>Acesse sua conta</h2>
                                <p class="lc-sub">Entre com suas credenciais para acessar a plataforma exclusiva.</p>
                                <div id="loginErr" class="login-err" style="display:none"></div>
                        
                                <!--begin::Form-->
                                <form id="frmLogin" class="form" action="#" autocomplete="off">
                                    <div class="fg">
                                        <label for="lEmail">E-mail</label>
                                        <input class="form-control" type="email" id="lEmail" name="lEmail" placeholder="seu@email.com.br" required autocomplete="username">
                                    </div>
                                    <div class="fg pwd-fg">
                                        <label for="lSenha">Senha</label>
                                        <input class="form-control" type="password" id="lSenha" name="lSenha" placeholder="••••••••" required autocomplete="current-password">
                                        <button type="button" class="eye-btn" onclick="fn_Viewpass()" title="Mostrar/ocultar senha">👁</button>
                                    </div>
                                    <div class="login-opts">
                                        <label class="chk-lembrar"><input type="checkbox" id="lLembrar"> Lembrar-me</label>
                                        <a href="https://www.aceca.com.br/#contato" class="link-senha">Esqueceu a senha?</a>
                                    </div>

                                    <!--begin::Actions-->
                                    <button type="submit" class="btn-entrar" id="btnEntrar">Entrar</button>
                                    <!--end::Actions-->
                                </form>
                                <!--end::Form-->
                                <p class="lc-cadastro">Ainda n&atilde;o &eacute; S&oacute;cio? <a href="https://www.aceca.com.br/#contato">Solicite sua associa&ccedil;&atilde;o</a></p>
                                <a href="https://www.aceca.com.br/" class="back-site">← Voltar ao Site</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>